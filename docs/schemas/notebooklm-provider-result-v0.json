{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wittgenstein.local/schemas/notebooklm-provider-result-v0.json",
  "title": "NotebookLM Provider Result v0",
  "type": "object",
  "required": ["contractVersion", "provider", "status", "ok", "authority"],
  "properties": {
    "contractVersion": {
      "const": "notebooklm-provider-result-v0"
    },
    "provider": {
      "const": "notebooklm"
    },
    "status": {
      "enum": ["unavailable", "not_ready", "failed", "captured"]
    },
    "ok": {
      "type": "boolean"
    },
    "runId": {
      "type": ["string", "null"]
    },
    "requestId": {
      "type": ["string", "null"]
    },
    "preflight": {
      "type": "object",
      "additionalProperties": true
    },
    "capture": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "enum": ["none", "cli", "python_api", "manual_export"]
        },
        "notebookId": {
          "type": ["string", "null"]
        },
        "notebookTitle": {
          "type": ["string", "null"]
        },
        "operation": {
          "type": ["string", "null"]
        },
        "capturedAt": {
          "type": ["string", "null"]
        },
        "rawTextPath": {
          "type": ["string", "null"]
        },
        "metadataPath": {
          "type": ["string", "null"]
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "details": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    },
    "authority": {
      "type": "object",
      "required": ["mayCreateClaims", "mayAuthorizeImplementation", "requiresLocalPromotion"],
      "properties": {
        "mayCreateClaims": { "type": "boolean" },
        "mayAuthorizeImplementation": { "type": "boolean" },
        "requiresLocalPromotion": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
