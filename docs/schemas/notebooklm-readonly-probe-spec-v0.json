{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wittgenstein.local/schemas/notebooklm-readonly-probe-spec-v0.json",
  "title": "NotebookLM Read-Only Probe Spec v0",
  "type": "object",
  "required": ["schemaVersion", "provider", "mode", "operation", "liveNotebookLMExecuted", "approvedNow", "futureCommand", "authority"],
  "properties": {
    "schemaVersion": { "const": "notebooklm-readonly-probe-spec-v0" },
    "provider": { "const": "notebooklm" },
    "mode": { "const": "spec_only" },
    "operation": { "const": "readonly-list" },
    "futureCommand": { "const": "notebooklm list" },
    "approvedNow": { "type": "boolean", "const": false },
    "liveNotebookLMExecuted": { "type": "boolean", "const": false },
    "manualGateRequired": { "type": "boolean", "const": true },
    "futureGate": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "forbiddenNow": {
      "type": "array",
      "items": { "type": "string" }
    },
    "futureArtifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "authority": {
      "type": "object",
      "required": ["mayCreateClaims", "mayAuthorizeImplementation", "requiresLocalPromotion"],
      "properties": {
        "mayCreateClaims": { "type": "boolean" },
        "mayAuthorizeImplementation": { "type": "boolean" },
        "requiresLocalPromotion": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
