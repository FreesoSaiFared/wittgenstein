{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wittgenstein.local/schemas/notebooklm-live-runner-dry-harness-v0.json",
  "title": "NotebookLM Live Runner Dry Harness v0",
  "type": "object",
  "required": ["schemaVersion", "provider", "mode", "status", "ok", "liveNotebookLMExecuted", "commandsExecuted", "authority"],
  "properties": {
    "schemaVersion": { "const": "notebooklm-live-runner-dry-harness-v0" },
    "provider": { "const": "notebooklm" },
    "mode": { "const": "live_runner_dry_harness" },
    "status": {
      "enum": ["gate_missing", "home_missing", "readonly_enable_missing", "live_execution_disabled", "would_execute_but_stubbed", "blocked"]
    },
    "ok": { "type": "boolean" },
    "experimentId": { "type": "string" },
    "requestedOperation": { "type": "string" },
    "wouldExecuteCommand": { "const": "notebooklm list" },
    "liveNotebookLMExecuted": { "type": "boolean", "const": false },
    "commandsExecuted": { "type": "array", "maxItems": 0 },
    "errors": { "type": "array" },
    "authority": {
      "type": "object",
      "required": ["mayCreateClaims", "mayAuthorizeImplementation", "requiresLocalPromotion"],
      "properties": {
        "mayCreateClaims": { "type": "boolean" },
        "mayAuthorizeImplementation": { "type": "boolean" },
        "requiresLocalPromotion": { "type": "boolean" },
        "providerOutputOnly": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
