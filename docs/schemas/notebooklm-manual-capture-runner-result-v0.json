{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wittgenstein.local/schemas/notebooklm-manual-capture-runner-result-v0.json",
  "title": "NotebookLM Manual Capture Runner Result v0",
  "type": "object",
  "required": ["schemaVersion", "provider", "mode", "status", "ok", "experimentId", "liveNotebookLMExecuted", "errors", "authority"],
  "properties": {
    "schemaVersion": { "const": "notebooklm-manual-capture-runner-result-v0" },
    "provider": { "const": "notebooklm" },
    "mode": { "const": "runner_skeleton" },
    "status": { "enum": ["plan_only", "blocked", "gate_missing", "home_missing"] },
    "ok": { "type": "boolean" },
    "experimentId": { "type": "string", "minLength": 1 },
    "requestedOperation": { "type": ["string", "null"] },
    "manualGatePresent": { "type": "boolean" },
    "notebooklmHomePresent": { "type": "boolean" },
    "liveNotebookLMExecuted": { "type": "boolean", "const": false },
    "commandsExecuted": { "type": "array", "items": { "type": "string" }, "maxItems": 0 },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "blocking": { "type": "boolean" },
          "details": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    },
    "authority": {
      "type": "object",
      "required": ["mayCreateClaims", "mayAuthorizeImplementation", "requiresLocalPromotion"],
      "properties": {
        "mayCreateClaims": { "type": "boolean" },
        "mayAuthorizeImplementation": { "type": "boolean" },
        "requiresLocalPromotion": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
