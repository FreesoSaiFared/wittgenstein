{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wittgenstein.local/schemas/patch-plan-ir-v0.json",
  "title": "PatchPlanIR v0 (future target only)",
  "description": "Minimal future-target schema for a Level B patch-plan compiler. This schema is documentation only and is not the current execution path.",
  "type": "object",
  "required": [
    "version",
    "status",
    "baseContext",
    "operations"
  ],
  "properties": {
    "version": {
      "const": "0.1.0"
    },
    "status": {
      "const": "future_target_only"
    },
    "baseContext": {
      "type": "object",
      "required": [
        "runId",
        "baseGitSha",
        "baseSourceSnapshot"
      ],
      "properties": {
        "runId": { "type": "string" },
        "baseGitSha": { "type": ["string", "null"] },
        "baseSourceSnapshot": { "type": "string" }
      },
      "additionalProperties": true
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "opId",
          "target",
          "authority"
        ],
        "properties": {
          "opId": { "type": "string" },
          "target": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "selector": { "type": ["string", "null"] }
            },
            "additionalProperties": true
          },
          "authority": {
            "type": "object",
            "required": ["claimIds", "decisionIds"],
            "properties": {
              "claimIds": {
                "type": "array",
                "items": { "type": "string" }
              },
              "decisionIds": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
